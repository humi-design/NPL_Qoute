# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=production
SECRET_KEY=change-this-to-a-secure-random-string

# Database Configuration (MySQL - Namecheap cPanel compatible)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=erp_fastener
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# File Upload Settings
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,webp,bmp,step,stp,iges,igs,dxf,dwg,zip

# Email Configuration (Optional - for notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Application Settings
COMPANY_NAME=NPL Fasteners
COMPANY_ADDRESS=Your Company Address
COMPANY_PHONE=+91-1234567890
COMPANY_EMAIL=sales@company.com
COMPANY_GST=GSTIN123456789

# Default Currency
DEFAULT_CURRENCY=INR
USD_RATE=83.0
EUR_RATE=90.0
GBP_RATE=100.0
AED_RATE=22.5

# Costing Defaults
DEFAULT_OVERHEAD_PERCENT=15
DEFAULT_PROFIT_PERCENT=20
DEFAULT_SCRAP_PERCENT=2
